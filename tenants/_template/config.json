{
  "slug": "your-shop-slug",
  "branding": {
    "shopName": "Your Shop Name",
    "logoUrl": "/tenants/your-shop-slug/logo.png",
    "colors": {
      "primary": "#1E5128",
      "accent": "#4E9F3D",
      "background": "#F8FBF6"
    }
  },
  "modules": {
    "insights": { "enabled": true, "order": 1 },
    "segments": { "enabled": true, "order": 2 },
    "campaigns": { "enabled": true, "order": 3 },
    "loyalty": { "enabled": true, "order": 4 },
    "menu": { "enabled": true, "order": 5 },
    "preferences": { "enabled": true, "order": 6 },
    "data": { "enabled": true, "order": 7 },
    "settings": { "enabled": true, "order": 8 }
  },
  "loyalty": {
    "enabled": true,
    "pointsPerRupee": 0.1,
    "pointValueRupees": 0.25
  },
  "receipts": {
    "enabled": true,
    "showItems": true,
    "footerNote": "optional closing line on every WhatsApp bill (delete if unwanted)"
  },
  "coupons": {
    "enabled": false,
    "tiers": [
      {
        "minAmount": 500,
        "discountType": "percent",
        "discountValue": 10,
        "validityDays": 30
      }
    ],
    "minDaysBetweenCoupons": 14,
    "codePrefix": "SHOP"
  },
  "qrCapture": {
    "enabled": true,
    "messageTemplate": "Hi {{shop_name}}! Adding my order {{token}} to my rewards ✨"
  },
  "brandVoice": {
    "tone": "describe how the shop talks to customers, e.g. 'friendly and to the point'",
    "language": "en-IN",
    "samplePhrases": ["phrases the shop actually uses with customers"],
    "avoid": ["things the shop never says"]
  },
  "festivals": [
    {
      "name": "Diwali",
      "date": "2026-11-08",
      "preWindowDays": 14,
      "categories": ["categories this festival drives for this shop"]
    }
  ],
  "posColumnMapping": {
    "phone": "<CSV header for customer phone>",
    "name": "<CSV header for customer name (optional — delete if absent)>",
    "email": "<CSV header for customer email (optional — delete if absent)>",
    "amount": "<CSV header for bill total>",
    "items": "<CSV header for the items cell>",
    "itemsDelimiter": ";",
    "itemFormat": "name|category|qty|unitPrice",
    "itemPartsDelimiter": "|",
    "timestamp": "<CSV header for bill date/time>",
    "dateFormat": "DD/MM/YYYY HH:mm",
    "locationId": "<CSV header for store/branch code (optional — delete if absent)>"
  },
  "channels": {
    "whatsapp": { "enabled": true, "number": "+91XXXXXXXXXX" },
    "email": { "enabled": false, "fromAddress": "hello@yourshop.example" },
    "callList": { "enabled": true, "minLtvThreshold": 5000 }
  }
}

{
  "name": "@hpas/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--conditions=development tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@hpas/db": "workspace:*",
    "@hpas/types": "workspace:*",
    "dayjs": "^1.11.11"
  },
  "devDependencies": {
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
